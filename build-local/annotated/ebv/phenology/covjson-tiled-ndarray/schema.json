{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "CoverageJSON TiledNdArray for partitioned range data",
  "type": "object",
  "required": [
    "type",
    "dataType",
    "axisNames",
    "shape",
    "tileSets"
  ],
  "properties": {
    "type": {
      "type": "string",
      "const": "TiledNdArray"
    },
    "dataType": {
      "type": "string"
    },
    "axisNames": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "shape": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "tileSets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tileShape": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "urlTemplate": {
            "type": "string"
          }
        }
      }
    }
  }
}