@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ebv: <https://w3id.org/ogc/hosted/ebv-phenology/> .

ebv: a owl:Ontology ; dcterms:title "EBV Phenology Ontology"@en , "Ontología Fenología EBV"@es , "EBV物候学本体"@zh , "Ontologia Fenologiei EBV"@ro .
ebv:EcosystemFunctioning a owl:Class ; rdfs:label "Ecosystem Functioning"@en , "Funcionamiento del Ecosistema"@es , "生态系统功能"@zh , "Funcționarea Ecosistemului"@ro .
ebv:EcosystemPhenology a owl:Class ; rdfs:subClassOf ebv:EcosystemFunctioning ; rdfs:label "Ecosystem Phenology"@en , "Fenología del Ecosistema"@es , "生态系统物候学"@zh , "Fenologia Ecosistemului"@ro .
ebv:StartOfVAP a owl:Class ; rdfs:subClassOf ebv:EcosystemPhenology ; rdfs:label "Start of Vegetation Active Period"@en , "Inicio del Periodo Activo de Vegetación"@es , "植被活跃期起始"@zh , "Începutul Perioadei Active a Vegetației"@ro .
ebv:PeakGreenness a owl:Class ; rdfs:subClassOf ebv:EcosystemPhenology ; rdfs:label "Peak Greenness"@en , "Máximo Verdor"@es , "最大绿度"@zh , "Verdețe Maximă"@ro .
ebv:StartOfSenescence a owl:Class ; rdfs:subClassOf ebv:EcosystemPhenology ; rdfs:label "Start of Senescence"@en , "Inicio de la Senescencia"@es , "衰老开始"@zh , "Începutul Senescenței"@ro .
ebv:ConiferousForest a owl:Class ; rdfs:label "Coniferous Forest"@en , "Bosque de Coníferas"@es , "针叶林"@zh , "Pădure de Conifere"@ro .
ebv:DeciduousForest a owl:Class ; rdfs:label "Deciduous Forest"@en , "Bosque Caduco"@es , "落叶林"@zh , "Pădure Caducă"@ro .
ebv:RemoteSensing a owl:Class ; rdfs:label "Remote Sensing"@en , "Teledetección"@es , "遥感"@zh , "Teledetecție"@ro .
ebv:GroundObservation a owl:Class ; rdfs:label "Ground Observation"@en , "Observación Terrestre"@es , "地面观察"@zh , "Observație la Teren"@ro .
ebv:vap_doy a owl:DatatypeProperty ; rdfs:label "VAP Day of Year"@en , "Día del Año VAP"@es , "VAP年日数"@zh , "Ziua Anului VAP"@ro .
ebv:entity_type a owl:ObjectProperty ; rdfs:label "entity type"@en , "tipo de entidad"@es , "实体类型"@zh , "tip de entitate"@ro .
